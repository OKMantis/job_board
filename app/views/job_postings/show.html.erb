<div class="w-full max-w-3xl mx-auto py-8">

  <%= link_to "← Back to jobs", job_postings_path,
        class: "inline-flex items-center text-sm font-medium text-sky-700 hover:text-sky-900 transition-colors duration-150" %>

  <div class="mt-6 pb-6 border-b border-sky-100">
    <div class="flex flex-wrap items-start gap-3">
      <h1 class="text-3xl font-bold text-sky-900 tracking-tight flex-1"><%= @job.title %></h1>
      <% if @job.featured %>
        <span class="mt-1 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
          Featured
        </span>
      <% end %>
    </div>

    <p class="text-base text-slate-600 mt-2">
      <%= @job.company.name %>
      <% if @job.company.location.present? %>
        <span class="mx-1.5 text-slate-300">·</span>
        <%= @job.company.location %>
      <% end %>
    </p>

    <div class="flex flex-wrap gap-2 mt-4">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-sky-100 text-sky-700">
        <%= @job.category.name %>
      </span>

      <% if @job.remote %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-sky-50 text-sky-600 border border-sky-200">
          Remote
        </span>
      <% end %>

      <% if @job.salary_min %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-slate-100 text-slate-700">
          $<%= number_with_delimiter(@job.salary_min) %> – $<%= number_with_delimiter(@job.salary_max) %>/yr
        </span>
      <% end %>
    </div>
  </div>

  <div class="mt-6 prose prose-slate prose-sm max-w-none text-slate-700 leading-relaxed">
    <%= simple_format @job.description %>
  </div>

  <p class="mt-6 text-xs text-slate-400">
    Expires <%= @job.expires_at.strftime("%B %d, %Y") %>
  </p>

  <% if @related.any? %>
    <div class="mt-10 pt-8 border-t border-sky-100">
      <h2 class="text-lg font-semibold text-sky-900 mb-4">
        More jobs in <%= @job.category.name %>
      </h2>

      <div class="space-y-2">
        <% @related.each do |job| %>
          <div class="flex items-center justify-between gap-4 p-4 bg-white border border-sky-200 rounded-xl hover:border-sky-400 transition-colors duration-150">
            <div>
              <%= link_to job.title, job_posting_path(job),
                    class: "text-sm font-medium text-sky-800 hover:text-sky-600 transition-colors duration-150" %>
              <p class="text-xs text-slate-500 mt-0.5"><%= job.company.name %></p>
            </div>
            <% if job.remote %>
              <span class="shrink-0 text-xs text-sky-600 font-medium">Remote</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
